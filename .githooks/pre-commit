#!/usr/bin/env bash
# MAGI pre-commit hook
# Runs governance checks and extraction tests when plugin files are modified.
# Install: git config core.hooksPath .githooks

set -euo pipefail

# Check if any staged files touch the MAGI plugin
STAGED=$(git diff --cached --name-only)
if ! echo "$STAGED" | grep -q '^plugins/magi/'; then
  exit 0
fi

echo "MAGI plugin files changed — running governance checks..."

echo ""
bash scripts/check-sizes.sh
echo ""
bash tests/test-extraction.sh

# Run benchmark regression if prompt files were changed
if echo "$STAGED" | grep -qE '(agents/|SKILL\.md|references/)'; then
  echo ""
  echo "Prompt files changed — running benchmark regression..."
  if [ -x scripts/benchmark-regression.sh ]; then
    bash scripts/benchmark-regression.sh
  else
    echo "WARN: scripts/benchmark-regression.sh not found or not executable — skipping"
  fi
fi

echo ""
echo "MAGI pre-commit checks passed."
